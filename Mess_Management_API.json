        {
          "name": "Register (Public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set('memberToken', jsonData.data.accessToken);",
                  "    pm.collectionVariables.set('token', jsonData.data.accessToken);",
                  "    pm.collectionVariables.set('memberRefreshToken', jsonData.data.refreshToken);",
                  "}",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has tokens', () => {",
                  "    pm.expect(jsonData.data.accessToken).to.exist;",
                  "    pm.expect(jsonData.data.refreshToken).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nurulla Hasan\",\n  \"email\": \"nurulla@example.com\",\n  \"phone\": \"+8801712345678\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
